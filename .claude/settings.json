{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/verify-before-commit.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/verify-playwright.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
