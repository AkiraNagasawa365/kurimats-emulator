{
  "name": "@kurimats/electron",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "node scripts/build.mjs && electron .",
    "build": "node scripts/build.mjs && node scripts/bundle-app.mjs && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "electron-store": "^10.0.0"
  },
  "devDependencies": {
    "electron": "41.1.1",
    "electron-builder": "^26.0.0",
    "tsx": "^4.19.0"
  },
  "build": {
    "appId": "com.kurimats.emulator",
    "productName": "kurimats",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"],
      "icon": "resources/icon.icns"
    },
    "files": [
      "dist/**/*",
      "resources/**/*",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": "app-content",
        "to": "app-content",
        "filter": ["**/*"]
      }
    ],
    "asarUnpack": []
  }
}
