{
  "name": "kurimats-emulator",
  "version": "0.1.0",
  "private": true,
  "description": "Claude Code並列実行エミュレータ - VS Code的WebアプリでClaude Codeを複数並列管理",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "dev:server": "npm run dev -w packages/server",
    "dev:client": "npm run dev -w packages/client"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "jsdom": "^29.0.1",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
